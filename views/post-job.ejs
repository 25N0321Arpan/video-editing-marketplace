<%- include('partials/header', { title: title, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null }) %>

<div class="container py-4" style="max-width: 760px;">
  <div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-plus-circle text-primary"></i> Post a New Job</h2>
    <p class="text-muted">Describe your video editing needs and set your budget</p>
  </div>

  <!-- Wallet Balance Warning -->
  <% if (typeof user !== 'undefined' && user) { %>
    <div class="alert alert-info d-flex align-items-center mb-4">
      <i class="bi bi-wallet2 me-2 fs-5"></i>
      <div>
        <strong>Wallet Balance: $<%= parseFloat(user.wallet_balance).toFixed(2) %></strong>
        <% if (user.wallet_balance <= 0) { %>
          <span class="text-danger ms-2">— You need funds to post a job! <a href="/wallet" class="alert-link">Add funds</a></span>
        <% } else { %>
          <span class="text-muted ms-2">— This amount will be deducted as escrow when you post the job.</span>
        <% } %>
      </div>
    </div>
  <% } %>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <form method="POST" action="/jobs/post" enctype="multipart/form-data" id="postJobForm">
        <div class="row g-3">
          <div class="col-12">
            <label for="title" class="form-label fw-semibold">Job Title <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="title" name="title" required
              placeholder="e.g. Edit 10-minute YouTube video with subtitles and transitions">
          </div>

          <div class="col-md-6">
            <label for="category" class="form-label fw-semibold">Category</label>
            <select class="form-select" id="category" name="category">
              <option value="general">General</option>
              <option value="youtube">YouTube</option>
              <option value="wedding">Wedding</option>
              <option value="corporate">Corporate</option>
              <option value="social-media">Social Media</option>
              <option value="music-video">Music Video</option>
              <option value="documentary">Documentary</option>
              <option value="short-film">Short Film</option>
            </select>
          </div>

          <div class="col-md-3">
            <label for="budget" class="form-label fw-semibold">Budget ($) <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text">$</span>
              <input type="number" class="form-control" id="budget" name="budget" required min="1" step="0.01"
                placeholder="50.00" oninput="checkBudget(this.value)">
            </div>
            <div id="budgetWarning" class="form-text text-danger d-none">
              <i class="bi bi-exclamation-triangle"></i> Budget exceeds wallet balance!
            </div>
          </div>

          <div class="col-md-3">
            <label for="deadline" class="form-label fw-semibold">Deadline</label>
            <input type="date" class="form-control" id="deadline" name="deadline"
              min="<%= new Date().toISOString().split('T')[0] %>">
          </div>

          <div class="col-12">
            <label for="description" class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
            <textarea class="form-control" id="description" name="description" rows="4" required
              placeholder="Describe your project, the style you want, any specific requirements..."></textarea>
          </div>

          <div class="col-12">
            <label for="instructions" class="form-label fw-semibold">Editing Instructions <span class="text-danger">*</span></label>
            <textarea class="form-control" id="instructions" name="instructions" rows="4" required
              placeholder="Specific instructions for the editor: cuts to make, music to add, effects needed, output format..."></textarea>
          </div>

          <div class="col-md-6">
            <label for="video_url" class="form-label fw-semibold">Source Video URL</label>
            <input type="url" class="form-control" id="video_url" name="video_url"
              placeholder="https://drive.google.com/...">
            <div class="form-text">Link to your raw footage (Google Drive, Dropbox, etc.)</div>
          </div>

          <div class="col-md-6">
            <label for="video_file" class="form-label fw-semibold">Or Upload Video File</label>
            <input type="file" class="form-control" id="video_file" name="video_file" accept="video/*">
            <div class="form-text">MP4, MOV, AVI, MKV (max 500MB)</div>
          </div>

          <div class="col-12 mt-2">
            <div class="d-flex gap-3">
              <button type="submit" class="btn btn-primary btn-lg fw-semibold px-5">
                <i class="bi bi-cloud-upload"></i> Post Job
              </button>
              <a href="/jobs" class="btn btn-outline-secondary btn-lg">Cancel</a>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
const walletBalance = <%= typeof user !== 'undefined' && user ? parseFloat(user.wallet_balance) : 0 %>;
function checkBudget(value) {
  const warning = document.getElementById('budgetWarning');
  if (parseFloat(value) > walletBalance) {
    warning.classList.remove('d-none');
  } else {
    warning.classList.add('d-none');
  }
}
</script>

<%- include('partials/footer') %>
