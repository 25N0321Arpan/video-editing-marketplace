<%- include('partials/header', { title: title, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null }) %>

<div class="container py-4">
  <!-- Welcome Banner -->
  <div class="row mb-4">
    <div class="col">
      <h2 class="fw-bold mb-1">
        Welcome back, <%= user.name.split(' ')[0] %>! <span class="wave">👋</span>
      </h2>
      <p class="text-muted">Here's what's happening with your account</p>
    </div>
    <div class="col-auto d-flex gap-2 align-items-center">
      <% if (user.role === 'owner' || user.role === 'both') { %>
        <a href="/jobs/post" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Post a Job</a>
      <% } %>
      <a href="/wallet" class="btn btn-outline-success"><i class="bi bi-wallet2"></i> $<%= parseFloat(user.wallet_balance).toFixed(2) %></a>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="row g-3 mb-4">
    <% if (user.role === 'owner' || user.role === 'both') { %>
      <div class="col-6 col-md-3">
        <div class="stat-card card border-0 shadow-sm text-center p-3">
          <div class="stat-icon bg-primary-subtle text-primary mx-auto mb-2"><i class="bi bi-briefcase-fill"></i></div>
          <h3 class="fw-bold mb-0"><%= stats.activeJobs %></h3>
          <small class="text-muted">Active Jobs</small>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card card border-0 shadow-sm text-center p-3">
          <div class="stat-icon bg-success-subtle text-success mx-auto mb-2"><i class="bi bi-check-circle-fill"></i></div>
          <h3 class="fw-bold mb-0"><%= stats.completedJobs %></h3>
          <small class="text-muted">Completed</small>
        </div>
      </div>
    <% } %>
    <% if (user.role === 'editor' || user.role === 'both') { %>
      <div class="col-6 col-md-3">
        <div class="stat-card card border-0 shadow-sm text-center p-3">
          <div class="stat-icon bg-warning-subtle text-warning mx-auto mb-2"><i class="bi bi-scissors"></i></div>
          <h3 class="fw-bold mb-0"><%= stats.activeEditing %></h3>
          <small class="text-muted">Editing Jobs</small>
        </div>
      </div>
    <% } %>
    <div class="col-6 col-md-3">
      <div class="stat-card card border-0 shadow-sm text-center p-3">
        <div class="stat-icon bg-info-subtle text-info mx-auto mb-2"><i class="bi bi-wallet2"></i></div>
        <h3 class="fw-bold mb-0">$<%= parseFloat(user.wallet_balance).toFixed(0) %></h3>
        <small class="text-muted">Wallet Balance</small>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Owner: Posted Jobs -->
    <% if (user.role === 'owner' || user.role === 'both') { %>
      <div class="col-lg-6">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-briefcase text-primary"></i> My Posted Jobs</h5>
            <a href="/jobs/post" class="btn btn-sm btn-primary"><i class="bi bi-plus"></i> New</a>
          </div>
          <div class="card-body p-0">
            <% if (ownedJobs && ownedJobs.length > 0) { %>
              <div class="list-group list-group-flush">
                <% ownedJobs.slice(0, 6).forEach(job => { %>
                  <a href="/jobs/<%= job.id %>" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between align-items-center">
                      <div class="flex-grow-1 me-3">
                        <div class="fw-semibold small"><%= job.title %></div>
                        <div class="text-muted" style="font-size:0.75rem;">$<%= parseFloat(job.budget).toFixed(2) %> &bull; <%= job.category %></div>
                      </div>
                      <% const statusColors = { open: 'success', in_progress: 'warning', completed: 'info', cancelled: 'secondary' }; %>
                      <span class="badge bg-<%= statusColors[job.status] || 'secondary' %>"><%= job.status.replace('_', ' ') %></span>
                    </div>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <div class="text-center py-4 text-muted">
                <i class="bi bi-briefcase" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0 small">No jobs posted yet.</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Editor: Editing Jobs -->
    <% if (user.role === 'editor' || user.role === 'both') { %>
      <div class="col-lg-6">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-scissors text-warning"></i> My Editing Jobs</h5>
            <a href="/jobs" class="btn btn-sm btn-outline-warning">Find Jobs</a>
          </div>
          <div class="card-body p-0">
            <% if (editingJobs && editingJobs.length > 0) { %>
              <div class="list-group list-group-flush">
                <% editingJobs.slice(0, 6).forEach(job => { %>
                  <a href="/jobs/<%= job.id %>" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between align-items-center">
                      <div class="flex-grow-1 me-3">
                        <div class="fw-semibold small"><%= job.title %></div>
                        <div class="text-muted" style="font-size:0.75rem;">$<%= parseFloat(job.budget).toFixed(2) %> &bull; by <%= job.owner_name %></div>
                      </div>
                      <% const statusColors2 = { open: 'success', in_progress: 'warning', completed: 'info', cancelled: 'secondary' }; %>
                      <span class="badge bg-<%= statusColors2[job.status] || 'secondary' %>"><%= job.status.replace('_', ' ') %></span>
                    </div>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <div class="text-center py-4 text-muted">
                <i class="bi bi-scissors" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0 small">No editing jobs yet. <a href="/jobs">Browse available jobs</a>.</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Recent Transactions -->
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3">
          <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history text-info"></i> Recent Transactions</h5>
          <a href="/wallet" class="btn btn-sm btn-outline-info">View All</a>
        </div>
        <div class="card-body p-0">
          <% if (transactions && transactions.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Date</th>
                  </tr>
                </thead>
                <tbody>
                  <% transactions.forEach(t => { %>
                    <tr>
                      <td>
                        <% const txColors = { deposit: 'success', withdrawal: 'danger', earning: 'primary', escrow: 'warning', commission: 'info', payment: 'secondary', escrow_release: 'info' }; %>
                        <span class="badge bg-<%= txColors[t.type] || 'secondary' %>"><%= t.type %></span>
                      </td>
                      <td class="small text-muted"><%= t.description || '-' %></td>
                      <td class="fw-semibold <%= t.amount >= 0 ? 'text-success' : 'text-danger' %>">
                        <%= t.amount >= 0 ? '+' : '' %>$<%= Math.abs(parseFloat(t.amount)).toFixed(2) %>
                      </td>
                      <td class="small text-muted"><%= new Date(t.created_at).toLocaleDateString() %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-4 text-muted">
              <i class="bi bi-receipt" style="font-size:2rem;"></i>
              <p class="mt-2 mb-0 small">No transactions yet.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
