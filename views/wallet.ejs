<%- include('partials/header', { title: title, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null }) %>

<div class="container py-4">
  <div class="row">
    <!-- Wallet Balance -->
    <div class="col-lg-4 mb-4">
      <div class="card shadow-sm border-0 text-center p-4 mb-3">
        <div class="text-muted mb-1 small">Current Balance</div>
        <h1 class="fw-bold text-success mb-0">$<%= parseFloat(user.wallet_balance).toFixed(2) %></h1>
      </div>

      <!-- Deposit Form -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-transparent py-3">
          <h6 class="mb-0 fw-bold"><i class="bi bi-plus-circle text-success"></i> Deposit Funds</h6>
        </div>
        <div class="card-body">
          <form method="POST" action="/wallet/deposit">
            <div class="input-group">
              <span class="input-group-text">$</span>
              <input type="number" class="form-control" name="amount" min="1" step="0.01" placeholder="Amount" required>
              <button type="submit" class="btn btn-success">Add</button>
            </div>
            <div class="d-flex gap-2 mt-2 flex-wrap">
              <% [10, 25, 50, 100].forEach(amt => { %>
                <button type="button" class="btn btn-outline-success btn-sm quick-deposit" data-amount="<%= amt %>">+$<%= amt %></button>
              <% }) %>
            </div>
          </form>
        </div>
      </div>

      <!-- Withdraw Form -->
      <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent py-3">
          <h6 class="mb-0 fw-bold"><i class="bi bi-dash-circle text-danger"></i> Withdraw Funds</h6>
        </div>
        <div class="card-body">
          <form method="POST" action="/wallet/withdraw">
            <div class="input-group">
              <span class="input-group-text">$</span>
              <input type="number" class="form-control" name="amount" min="1" step="0.01"
                max="<%= user.wallet_balance %>" placeholder="Amount" required>
              <button type="submit" class="btn btn-danger"
                onclick="return confirm('Confirm withdrawal?')">Withdraw</button>
            </div>
            <div class="form-text">Max: $<%= parseFloat(user.wallet_balance).toFixed(2) %></div>
          </form>
        </div>
      </div>
    </div>

    <!-- Transaction History -->
    <div class="col-lg-8">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent py-3">
          <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history text-primary"></i> Transaction History</h5>
        </div>
        <div class="card-body p-0">
          <% if (transactions && transactions.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Date</th>
                  </tr>
                </thead>
                <tbody>
                  <% transactions.forEach(t => { %>
                    <tr>
                      <td>
                        <% const txColors = { deposit: 'success', withdrawal: 'danger', earning: 'primary', escrow: 'warning', commission: 'info', payment: 'secondary', escrow_release: 'info' }; %>
                        <span class="badge bg-<%= txColors[t.type] || 'secondary' %>"><%= t.type %></span>
                      </td>
                      <td class="small text-muted"><%= t.description || '-' %></td>
                      <td class="fw-semibold <%= t.amount >= 0 ? 'text-success' : 'text-danger' %>">
                        <%= t.amount >= 0 ? '+' : '' %>$<%= Math.abs(parseFloat(t.amount)).toFixed(2) %>
                      </td>
                      <td class="small text-muted"><%= new Date(t.created_at).toLocaleDateString() %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-receipt" style="font-size: 3rem;"></i>
              <p class="mt-3 mb-0">No transactions yet. <a href="/wallet/deposit">Add funds</a> to get started.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.quick-deposit').forEach(btn => {
  btn.addEventListener('click', () => {
    const form = btn.closest('form');
    form.querySelector('input[name="amount"]').value = btn.dataset.amount;
  });
});
</script>

<%- include('partials/footer') %>
