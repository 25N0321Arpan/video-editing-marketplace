<%- include('partials/header', { title: title, user: typeof user !== 'undefined' ? user : null, success: null, error: typeof error !== 'undefined' ? error : null }) %>

<div class="container py-5" style="max-width: 480px;">
  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <i class="bi bi-camera-video-fill text-primary" style="font-size: 2.5rem;"></i>
        <h2 class="fw-bold mt-2">Welcome Back</h2>
        <p class="text-muted">Sign in to your VideoMarket account</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger">
          <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/login" novalidate>
        <div class="mb-3">
          <label for="email" class="form-label fw-semibold">Email Address</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" required autofocus>
          </div>
        </div>
        <div class="mb-4">
          <label for="password" class="form-label fw-semibold">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required>
          </div>
        </div>
        <button type="submit" class="btn btn-primary w-100 btn-lg fw-semibold">
          <i class="bi bi-box-arrow-in-right"></i> Sign In
        </button>
      </form>

      <hr class="my-4">
      <p class="text-center text-muted mb-0">
        Don't have an account? <a href="/register" class="text-decoration-none fw-semibold">Create one free</a>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
