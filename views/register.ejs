<%- include('partials/header', { title: title, user: typeof user !== 'undefined' ? user : null, success: null, error: typeof error !== 'undefined' ? error : null }) %>

<div class="container py-5" style="max-width: 520px;">
  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <i class="bi bi-camera-video-fill text-primary" style="font-size: 2.5rem;"></i>
        <h2 class="fw-bold mt-2">Join VideoMarket</h2>
        <p class="text-muted">Create your free account today</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger">
          <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/register" novalidate>
        <div class="mb-3">
          <label for="name" class="form-label fw-semibold">Full Name</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-person"></i></span>
            <input type="text" class="form-control" id="name" name="name" placeholder="John Doe" required autofocus>
          </div>
        </div>
        <div class="mb-3">
          <label for="email" class="form-label fw-semibold">Email Address</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" required>
          </div>
        </div>
        <div class="mb-3">
          <label for="password" class="form-label fw-semibold">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input type="password" class="form-control" id="password" name="password" placeholder="At least 6 characters" required minlength="6">
          </div>
        </div>
        <div class="mb-4">
          <label for="role" class="form-label fw-semibold">I want to...</label>
          <select class="form-select" id="role" name="role" required>
            <option value="both" selected>Both post and edit videos</option>
            <option value="owner">Post videos for editing (Video Owner)</option>
            <option value="editor">Edit videos (Video Editor)</option>
          </select>
          <div class="form-text">You can always change this later in your profile.</div>
        </div>
        <button type="submit" class="btn btn-primary w-100 btn-lg fw-semibold">
          <i class="bi bi-person-plus"></i> Create Account
        </button>
      </form>

      <hr class="my-4">
      <p class="text-center text-muted mb-0">
        Already have an account? <a href="/login" class="text-decoration-none fw-semibold">Sign in</a>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
